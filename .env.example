# Server
PORT=3000
HTTPS_PORT=3443
HOST=0.0.0.0
NODE_ENV=development

# Session
SESSION_SECRET=your-session-secret-here

# Security
ENCRYPTION_KEY=           # Required for API key encryption (32+ random chars)
BETA_CODE=401483          # Beta access code

# Database
DB_PATH=./server/database.sqlite

# SMTP (email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yamato.com

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=false

# SSL (optional, for local HTTPS)
SSL_KEY_PATH=./server/ssl/key.pem
SSL_CERT_PATH=./server/ssl/cert.pem
